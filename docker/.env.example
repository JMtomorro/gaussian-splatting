# Copy to docker/.env and adjust paths for your machine.
# docker compose loads docker/.env automatically when using -f docker/docker-compose.yml

# Dataset root (nerf_synthetic, tandt_db, etc.)
GS_DATA=/home/sjm/Habitat/dataset/gaussian-splatting

# Training outputs (persist across container runs)
GS_OUTPUT=/home/sjm/Habitat/project/gaussian-splatting/output

# Cache (torch hub, etc.)
GS_CACHE=/home/sjm/.cache/gs-docker

# Optional: pin GPU, e.g. 0 or 0,1
NVIDIA_VISIBLE_DEVICES=all
